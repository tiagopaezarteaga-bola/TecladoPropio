<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Teclado Pegar"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Activa el teclado en Ajustes\n2. Cambia al teclado desde cualquier app"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnEnableKeyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Activar teclado en Ajustes"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSwitchKeyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cambiar de teclado" />

</LinearLayout>
